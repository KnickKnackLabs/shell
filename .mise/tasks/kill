#!/usr/bin/env bash
#MISE description="Stop a shell"
#USAGE arg "<name>" help="Session name to kill"
set -euo pipefail

NAME="${usage_name:-}"

if [ -z "$NAME" ]; then
  echo "Error: session name required" >&2
  echo "Usage: shell kill <name>" >&2
  exit 1
fi

if ! command -v zmx >/dev/null 2>&1; then
  echo "Error: zmx is required but not installed" >&2
  exit 1
fi

if ! zmx list --short 2>/dev/null | grep -qx "$NAME"; then
  echo "Error: no session named '$NAME'" >&2
  exit 1
fi

zmx kill "$NAME"
