#!/usr/bin/env bash
#MISE description="List active shells"
#USAGE flag "--json" help="Output as JSON"
set -euo pipefail

if ! command -v zmx >/dev/null 2>&1; then
  echo "Error: zmx is required but not installed" >&2
  exit 1
fi

JSON="${usage_json:-false}"

SESSIONS_JSON=$(zmx list --json 2>/dev/null)

if [ "$JSON" = "true" ]; then
  printf '%s\n' "$SESSIONS_JSON" | jq -c '[.[] | {
    name: (.name // ""),
    pid: (.pid // 0),
    clients: (.clients // 0),
    created: (.created // .created_at // 0),
    cmd: (.cmd // ""),
    ended: (if ((.status // "") | startswith("exited")) then (.ended // .ended_at // .created_at // 1) else -1 end),
    exit_code: (if ((.status // "") | startswith("exited")) then (.exit_code // -1) else -1 end)
  }]'
else
  count=$(printf '%s\n' "$SESSIONS_JSON" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo "No active shells."
  else
    printf '%s\n' "$SESSIONS_JSON" | jq -r '.[] | [
      (.name // ""),
      (if ((.status // "") | startswith("exited")) then "exited (\(.exit_code // "?"))" else (.status // "") end),
      (.cmd // "")
    ] | @tsv' | while IFS=$'\t' read -r name status cmd; do
      printf "%-30s %-15s %s\n" "$name" "$status" "$cmd"
    done
  fi
fi
