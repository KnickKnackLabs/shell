#!/usr/bin/env bash
#MISE description="Check if a shell is running"
#USAGE arg "<name>" help="Session name"
#USAGE flag "--json" help="Output as JSON"
set -euo pipefail

NAME="${usage_name:-}"

if [ -z "$NAME" ]; then
  echo "Error: session name required" >&2
  echo "Usage: shell status <name>" >&2
  exit 1
fi

if ! command -v zmx >/dev/null 2>&1; then
  echo "Error: zmx is required but not installed" >&2
  exit 1
fi

JSON="${usage_json:-false}"

SESSION_JSON=$(zmx list --json 2>/dev/null | jq -c --arg name "$NAME" 'first(.[] | select(.name == $name)) // empty')

if [ -z "$SESSION_JSON" ]; then
  if [ "$JSON" = "true" ]; then
    printf '{"name":"%s","status":"not found"}\n' "$NAME"
  else
    echo "not found"
  fi
  exit 1
fi

ZMX_STATUS=$(printf '%s' "$SESSION_JSON" | jq -r '.status // ""')
EXIT_CODE=$(printf '%s' "$SESSION_JSON" | jq -r '.exit_code // empty')

case "$ZMX_STATUS" in
  exited*)
    STATUS="exited"
  ;;
  unreachable)
    STATUS="unreachable"
    EXIT_CODE=""
  ;;
  *)
    STATUS="running"
    EXIT_CODE=""
  ;;
esac

if [ "$JSON" = "true" ]; then
  if [ -n "$EXIT_CODE" ]; then
    printf '{"name":"%s","status":"%s","exit_code":%s}\n' "$NAME" "$STATUS" "$EXIT_CODE"
  else
    printf '{"name":"%s","status":"%s"}\n' "$NAME" "$STATUS"
  fi
else
  if [ "$STATUS" = "exited" ] && [ -n "$EXIT_CODE" ]; then
    echo "$STATUS ($EXIT_CODE)"
  else
    echo "$STATUS"
  fi
fi
